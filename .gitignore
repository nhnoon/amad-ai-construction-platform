attached_assets/

# Python
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
.pythonlibs/
.venv/
venv/

# Environment files
.env
backend/.env
!.env.example
!backend/.env.example

# Database files and backups
*.sql
*.dump
*.tar
backend/data/*.sql
backend/data/*.dump
backups/

# Local database files
*.db
*.sqlite3
*.postgres_dump

# Logs
*.log
logs/

# Test and debug files
test_*.py
*_test.py
backend/test_*.py
backend/*_test.py
screenshots/

# Generated API client files
# These ARE intentionally tracked in git so the build works after a fresh clone
# without requiring a `pnpm --filter @workspace/api-spec run codegen` step.
# If you change openapi.yaml, run codegen and commit the updated generated files.
# lib/api-client-react/src/generated/
# lib/api-zod/src/generated/
