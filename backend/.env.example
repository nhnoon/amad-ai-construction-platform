# Copy this file to .env and fill in values for local development.
# In Replit, these are set via Secrets / Environment Variables.

# ── Database ────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/construction_ai

# ── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Security ────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-long-random-string-at-least-32-chars
SESSION_SECRET=replace-with-a-long-random-session-secret

# ── App ─────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true

# ── LLM Provider (provider-agnostic) ────────────────────────
# Supported: mock | openai | anthropic | openrouter | hermes
LLM_PROVIDER=mock
LLM_MODEL=mock-model
# LLM_API_KEY=sk-...
# LLM_BASE_URL=https://api.openai.com/v1

# ── Hermes Agent (local, LLM_PROVIDER=hermes) ───────────────
# Requires: Hermes Agent CLI installed locally, an isolated "amad" Hermes
# profile (see `hermes profile create amad --clone`), and Ollama serving the
# model below. No API key needed — auth is handled inside Hermes's own
# profile config against the local Ollama endpoint.
# LLM_PROVIDER=hermes
# LLM_MODEL=qwen2.5:3b
# HERMES_BIN=                     # optional; auto-detected via PATH if unset
# HERMES_PROFILE=amad
# HERMES_PROVIDER=ollama-launch
# HERMES_BASE_URL=http://127.0.0.1:11434/v1
# HERMES_TIMEOUT_SECONDS=240

# ── Switching providers ──────────────────────────────────────
# Only one LLM_PROVIDER block should be active at a time. To switch:
#   mock       -> LLM_PROVIDER=mock (no key needed)
#   openrouter -> LLM_PROVIDER=openrouter, LLM_API_KEY=sk-or-..., LLM_BASE_URL=https://openrouter.ai/api/v1
#   hermes     -> LLM_PROVIDER=hermes, LLM_MODEL=qwen2.5:3b (see block above)
# Restart the backend after changing LLM_PROVIDER — the provider is cached
# per-process (see app/ai/providers/factory.py get_llm_provider()).
