# Copy this file to .env and fill in values for local development.
# In Replit, these are set via Secrets / Environment Variables.

# ── Database ────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/construction_ai

# ── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Security ────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-long-random-string-at-least-32-chars
SESSION_SECRET=replace-with-a-long-random-session-secret

# ── App ─────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true

# ── LLM Provider (provider-agnostic) ────────────────────────
# Supported: mock | openai | anthropic | openrouter
LLM_PROVIDER=mock
LLM_MODEL=mock-model
# LLM_API_KEY=sk-...
# LLM_BASE_URL=https://api.openai.com/v1
